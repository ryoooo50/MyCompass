# ============================================================
# My Compass v2 — 環境変数テンプレート
# ============================================================
# このファイルをコピーして .env.local を作成し、実際の値を入力してください。
# .env.local は gitignore されているのでコミットされません。
# Vercel 本番環境では Vercel ダッシュボードに同じ変数を設定してください。
# ============================================================

# ------ Supabase（必須） ------
# Supabase ダッシュボード > Settings > API から取得
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ------ アプリURL ------
# ローカル開発はそのまま。Vercel 本番は Vercel が自動設定するため入力不要。
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ------ Web Push VAPID（Phase 1: 通知機能） ------
# ターミナルで以下を実行して生成: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=ryoma.kojima.0319@gmail.com

# ------ Google OAuth の設定先について ------
# Google Client ID / Secret は Supabase ダッシュボードに直接入力します。
# このファイルへの記載は不要です。
# Supabase > Authentication > Providers > Google を参照してください。

# ------ Notion API（Phase 2） ------
# Notion Integration Token: Notion設定 > インテグレーション から取得
NOTION_INTEGRATION_TOKEN=secret_your_token_here
# Notion データベース ID: 対象DBのURLから取得
NOTION_DATABASE_ID=your_database_id_here
